// =====================================================
// image2cpp Horizontal - 1 bit per pixel için doğru çizim
// =====================================================
void drawManualBitmap(int x, int y, const unsigned char* bitmap, int w, int h, uint16_t color) {
  int byteWidth = (w + 7) / 8;

  tft.startWrite();
  for (int j = 0; j < h; j++) {
    for (int i = 0; i < w; i++) {
      uint8_t b = pgm_read_byte(bitmap + j * byteWidth + i / 8);
      if (b & (0x80 >> (i & 7))) {
        tft.drawPixel(x + i, y + j, color);
      }
    }
  }
  tft.endWrite();
}

void setup() {
  Serial.begin(115200);
  tft.init();
  tft.setRotation(0);
  tft.fillScreen(TFT_BLACK);
  drawUI();
}

void loop() {
  if (Serial.available() > 0) {
    String data = Serial.readStringUntil('*');
    parseData(data);
    updateScreen();
  }
}

void parseData(String data) {
  int indices[12];
  int count = 0;

  for (int i = 0; i < data.length(); i++) {
    if (data[i] == ',' && count < 12) {
      indices[count++] = i;
    }
  }

  if (count < 12) return;

  cpuT = data.substring(0, indices[0]);
  cpuL = data.substring(indices[0] + 1, indices[1]);
  cpuF = data.substring(indices[1] + 1, indices[2]);
  gpuT = data.substring(indices[2] + 1, indices[3]);
  gpuL = data.substring(indices[3] + 1, indices[4]);
  gpuF = data.substring(indices[4] + 1, indices[5]);
  vram = data.substring(indices[5] + 1, indices[6]);
  fan  = data.substring(indices[6] + 1, indices[7]);
  pwr  = data.substring(indices[7] + 1, indices[8]);
  ram  = data.substring(indices[8] + 1, indices[9]);
  netD = data.substring(indices[9] + 1, indices[10]);
  netU = data.substring(indices[10] +1 , indices[11]);
  deneme =data.substring(indices[11] + 1);
}
void drawBar(int x, int y, int w, int h, float percent, uint16_t color) {
  // Dış çerçeve
  tft.drawRect(x, y, w, h, TFT_WHITE);
  
  // İçerideki doluluk miktarı (yüzdeye göre hesaplanır)
  int fillWidth = (w - 4) * (percent / 100.0);
  if (fillWidth < 0) fillWidth = 0;
  if (fillWidth > (w - 4)) fillWidth = w - 4;

  // Önce içini temizle (Eski barın kalıntısı kalmasın diye)
  tft.fillRect(x + 2, y + 2, w - 4, h - 4, TFT_BLACK);
  
  // Yeni barı çiz
  tft.fillRect(x + 2, y + 2, fillWidth, h - 4, color);
}

void drawUI() {
  tft.fillScreen(TFT_BLACK);

  // Çerçeveler
  tft.drawRoundRect(1, 5, 237, 95, 5, TFT_RED);
  tft.drawRoundRect(1, 105, 237, 115, 5, TFT_GREEN);
  tft.drawRoundRect(1, 225, 237, 90, 5, TFT_BLUE);

  // Logolar için arka plan temizle
  tft.fillRect(10, 30, 48, 48, TFT_BLACK);
  tft.fillRect(10, 130, 62, 62, TFT_BLACK);

  // CPU logo
 // drawManualBitmap(10, 40, epd_bitmap_cpu_logo, 48, 48, TFT_RED);

  // GPU logo
 // drawManualBitmap(10, 130, epd_bitmap_gpu_logo, 62, 62, TFT_GREEN);

  // Başlıklar
  tft.setTextSize(1);
  tft.setTextColor(TFT_LIGHTGREY, TFT_BLACK);
  tft.setTextDatum(TL_DATUM);

  tft.drawString("AMD Ryzen 7", 10, 10);
  tft.drawString("9700X", 10, 20);
  tft.drawString("TEMP", 95, 12); tft.drawString("LOAD %", 185, 12);
  tft.drawString("GeForce", 10, 110);
  tft.drawString("RTX 5070", 10, 120);
  tft.drawString("TEMP", 95, 112); tft.drawString("LOAD %", 185, 112);
  tft.drawString("RAM MEMORY / 32GB", 10, 230);
  tft.drawString("NETWORK (Wi-Fi)", 130, 230);
}
