  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.drawString(cpuL, 230, 35);

 
  tft.setTextSize(2);
  tft.drawString(gpuL, 230, 135);

  // Frekanslar - Kalıntı yapan asıl yer
  tft.setTextSize(2);
  tft.setTextDatum(TL_DATUM);
  
  // CPU Frekans: "4500" yazıp yanına sabit " MHz" ekliyoruz. 
  // Eski değerden kalanları temizlemek için sonuna 2-3 boşluk bırakıyoruz.
  tft.setTextColor(TFT_GREEN, TFT_BLACK);
  tft.drawString(cpuF +" MHz", 70, 65); 

  // GPU Frekans
  tft.setTextColor(TFT_GREEN, TFT_BLACK);
  tft.drawString(gpuF + " MHz   ", 80, 170); 

  // Alt GPU bilgiler (Kalıntı kalmaması için sonlarına boşluk)
