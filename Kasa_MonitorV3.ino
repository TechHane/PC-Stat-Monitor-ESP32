    drawManualBitmap(10, 130, epd_bitmap_gpu_logo, 62, 62, TFT_RED);
  } 
  else if (currentgpuTemp >= 50.0) {
    tft.setTextColor(TFT_ORANGE, TFT_BLACK);  // 65-79 derece arası TURUNCU
    drawManualBitmap(10, 130, epd_bitmap_gpu_logo, 62, 62, TFT_ORANGE);
  } 
  else {
    tft.setTextColor(TFT_WHITE, TFT_BLACK);   // 65 altı normal BEYAZ
