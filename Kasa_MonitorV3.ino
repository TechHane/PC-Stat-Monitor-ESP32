  float ramPercent = (ramGB / 32) * 100.0;
  if (ramPercent > 100.0) ramPercent = 100.0; // Taşırma yapmasın

  // Barı çizdirelim (Koordinatlar: X=75, Y=215, Genişlik=150, Yükseklik=10)
  drawBar(15, 285, 80, 15, ramPercent, TFT_YELLOW);

