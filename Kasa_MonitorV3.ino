  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.drawString("VRAM: " + vram + " MB / 12GB   ", 80, 195);
  tft.drawString("RPM:" + fan + "  ", 170, 205);
  tft.drawString("PWR:" + pwr + "W   ", 80, 205);
  // CPU FAN YÜZDE
