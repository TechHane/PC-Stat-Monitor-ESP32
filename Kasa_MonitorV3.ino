  float vramPercent = (vramGB / 12000) * 100.0;
  if (vramPercent > 100.0) vramPercent = 100.0; // Taşırma yapmasın

  // Barı çizdirelim (Koordinatlar: X=75, Y=215, Genişlik=150, Yükseklik=10)
