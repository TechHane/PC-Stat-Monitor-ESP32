void updateScreen() {
  float currentCpuTemp = cpuT.toFloat(); // String olan sıcaklığı sayıya çeviriyoruz

  // CPU RENK DEGİSİMLERİ
  if (currentCpuTemp >= 75.0) {
    tft.setTextColor(TFT_RED, TFT_BLACK);     // 80 derece ve üstü KIRMIZI
    drawManualBitmap(10, 40, epd_bitmap_cpu_logo, 48, 48, TFT_RED);
  } 
  else if (currentCpuTemp >= 50.0) {
    tft.setTextColor(TFT_ORANGE, TFT_BLACK);  // 65-79 derece arası TURUNCU
    drawManualBitmap(10, 40, epd_bitmap_cpu_logo, 48, 48, TFT_ORANGE);
  } 
  else {
    tft.setTextColor(TFT_WHITE, TFT_BLACK);   // 65 altı normal BEYAZ
    drawManualBitmap(10, 40, epd_bitmap_cpu_logo, 48, 48, TFT_GREEN);
  }
  tft.setTextDatum(TR_DATUM); 
  tft.setTextSize(3);
  tft.drawString(cpuT + " ", 180, 35); // Bir boşluk eklemek karakter kısalınca kalıntıyı siler

// GPU RENK DEGİSİMLERİ
  float currentgpuTemp = gpuT.toFloat(); // String olan sıcaklığı sayıya çeviriyoruz
  if (currentgpuTemp >= 75.0) {
