  }
  tft.setTextDatum(TR_DATUM); 
  tft.setTextSize(3);
  tft.drawString(gpuT + " ", 190, 135);

  //tft.setTextSize(3);
  //tft.setTextColor(TFT_WHITE, TFT_BLACK);
  
  // Sıcaklık ve Load değerleri için (Gelen string sonuna boşluk ekleyerek kalıntıyı eziyoruz)
